{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "User gym subscription details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planName": { "type": "string" },
        "price": { "type": "string" },
        "duration": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "expired", "pending"] },
        "paymentId": { "type": "string" }
      },
      "required": ["userId", "planName", "price", "duration", "startDate", "endDate", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "User subscription records"
    }
  }
}
